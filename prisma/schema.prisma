// ============================================================
// ===========  GELİŞMİŞ ERP: TEKLİF / PAZARLIK  ==============
// ============================================================

enum OfferStatus {
  PENDING // Beklemede
  COUNTERED // Karşı teklif verildi
  ACCEPTED // Kabul edildi
  REJECTED // Reddedildi
  WITHDRAWN // Geri çekildi
  EXPIRED // Süresi doldu
}

// Müşterinin bir ilana verdiği teklif (alım/kiralama pazarlığı)
model PropertyOffer {
  id      String @id @default(cuid()) @map("_id")
  offerNo String @unique

  offerType ListingType // SALE / RENT / SHORT_RENT
  status    OfferStatus @default(PENDING)

  amount        Float // Teklif tutarı
  currency      String    @default("TRY")
  counterAmount Float? // Ofisin/satıcının verdiği karşı teklif
  depositOffer  Float? // Önerilen kapora / depozito
  message       String? // Teklif notu
  validUntil    DateTime? // Teklif geçerlilik süresi

  acceptedAt   DateTime?
  rejectedAt   DateTime?
  rejectReason String?

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  propertyId String
  property   PropertyRealEstate @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  clientId   String
  clientName String
  client     PropertyClient @relation(fields: [clientId], references: [id])

  agentId   String?
  agentName String?
  agent     Agent?  @relation(fields: [agentId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  reservation PropertyReservation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([listingId])
  @@index([clientId])
  @@index([status])
  @@map("property-offers")
}

enum ReservationStatus {
  ACTIVE // Aktif rezervasyon
  CONVERTED // Sözleşmeye dönüştü
  CANCELLED // İptal edildi
  EXPIRED // Süresi doldu
  REFUNDED // Kapora iade edildi
}

// Kabul edilen teklif sonrası kapora ile mülkün rezerve edilmesi
model PropertyReservation {
  id            String @id @default(cuid()) @map("_id")
  reservationNo String @unique

  status        ReservationStatus @default(ACTIVE)
  depositAmount Float // Alınan kapora
  currency      String            @default("TRY")
  reservedUntil DateTime // Rezervasyon bitiş tarihi
  notes         String?
  cancelReason  String?
  refundedAt    DateTime?

  offerId String?        @unique
  offer   PropertyOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  propertyId String
  property   PropertyRealEstate @relation(fields: [propertyId], references: [id])

  clientId   String
  clientName String
  client     PropertyClient @relation(fields: [clientId], references: [id])

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([propertyId])
  @@index([status])
  @@map("property-reservations")
}

// ============================================================
// ============  GELİŞMİŞ ERP: KOMİSYON & MUHASEBE  ===========
// ============================================================

enum CommissionSide {
  BUYER // Alıcı tarafı
  SELLER // Satıcı tarafı
  TENANT // Kiracı tarafı
  LANDLORD // Mülk sahibi tarafı
}

enum CommissionStatus {
  PENDING // Beklemede
  INVOICED // Faturalandı
  PAID // Ödendi
  PARTIAL // Kısmi ödendi
  CANCELLED // İptal
}

// Sözleşme başına danışman komisyonu (taraf bazlı, co-broking destekli)
model Commission {
  id String @id @default(cuid()) @map("_id")

  contractId String
  contract   PropertyContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  agentId   String
  agentName String
  agent     Agent  @relation(fields: [agentId], references: [id])

  side       CommissionSide
  baseAmount Float // Üzerinden hesaplanan tutar (satış/kira bedeli)
  percentage Float? // Komisyon oranı (%)
  amount     Float // Komisyon tutarı
  currency   String           @default("TRY")
  status     CommissionStatus @default(PENDING)
  paidAt     DateTime?
  notes      String?

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([contractId])
  @@index([agentId])
  @@index([status])
  @@map("commissions")
}

enum InvoiceTypeGayrimenkul {
  COMMISSION // Komisyon faturası
  RENT // Kira faturası
  SERVICE // Hizmet faturası
  OTHER
}

enum InvoiceStatusGayrimenkul {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

// Ofisin kestiği fatura (komisyon / kira / hizmet)
model AgencyInvoice {
  id        String @id @default(cuid()) @map("_id")
  invoiceNo String @unique

  type   InvoiceTypeGayrimenkul
  status InvoiceStatusGayrimenkul @default(DRAFT)

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  paidDate  DateTime?

  // Fatura edilen taraf bilgileri (snapshot)
  billToName    String
  billToTaxNo   String?
  billToAddress String?
  billToEmail   String?

  subtotal  Float
  taxRate   Float?  @default(20) // KDV (%)
  taxAmount Float?
  total     Float
  currency  String  @default("TRY")
  notes     String?

  contractId String?
  contract   PropertyContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  clientId String?
  client   PropertyClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  items AgencyInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([status])
  @@map("agency-invoices")
}

model AgencyInvoiceItem {
  id        String        @id @default(cuid()) @map("_id")
  invoiceId String
  invoice   AgencyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float  @default(1)
  unitPrice   Float
  amount      Float

  @@index([invoiceId])
  @@map("agency-invoice-items")
}

enum ExpenseCategoryGayrimenkul {
  RENT // Ofis kirası
  SALARY // Maaş
  MARKETING // Pazarlama / ilan yayını
  UTILITIES // Faturalar (elektrik/su/internet)
  COMMISSION // Danışman komisyonu
  MAINTENANCE // Bakım/onarım
  TAX // Vergi
  OTHER
}

// Ofis giderleri
model AgencyExpense {
  id String @id @default(cuid()) @map("_id")

  category      ExpenseCategoryGayrimenkul
  title         String
  amount        Float
  currency      String                     @default("TRY")
  date          DateTime                   @default(now())
  paymentMethod String?
  receiptUrl    String?
  vendor        String? // Tedarikçi / ödeme yapılan kişi
  notes         String?

  agentId String? // Maaş/komisyon gideri ise ilgili danışman
  agent   Agent?  @relation(fields: [agentId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([category])
  @@map("agency-expenses")
}

enum PayrollStatus {
  PENDING
  PAID
  CANCELLED
}

// Danışman maaş / prim bordrosu (aylık)
model AgentPayroll {
  id String @id @default(cuid()) @map("_id")

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  periodMonth Int // 1-12
  periodYear  Int
  baseSalary  Float  @default(0)
  commission  Float  @default(0) // Döneme ait komisyon toplamı
  bonus       Float  @default(0)
  deductions  Float  @default(0)
  netPay      Float
  currency    String @default("TRY")

  status PayrollStatus @default(PENDING)
  paidAt DateTime?
  notes  String?

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, periodYear, periodMonth])
  @@index([agencyId])
  @@map("agent-payrolls")
}

// ============================================================
// ========  GELİŞMİŞ ERP: BAKIM & İLETİŞİM & BİLDİRİM  =======
// ============================================================

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN // Açık
  IN_PROGRESS // İşlemde
  RESOLVED // Çözüldü
  CANCELLED // İptal
}

// Mülk bakım / arıza talebi (özellikle yönetilen kiralık portföy için)
model MaintenanceRequest {
  id        String @id @default(cuid()) @map("_id")
  requestNo String @unique

  title       String
  description String?
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)

  cost        Float?
  currency    String    @default("TRY")
  vendor      String? // Usta / tedarikçi
  scheduledAt DateTime?
  resolvedAt  DateTime?
  resolution  String?

  propertyId String
  property   PropertyRealEstate @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  contractId String?
  contract   PropertyContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  clientId String? // Talebi açan kiracı
  client   PropertyClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  agentId String? // Atanan/sorumlu danışman
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([propertyId])
  @@index([status])
  @@map("maintenance-requests")
}

enum CommunicationChannel {
  CALL // Telefon görüşmesi
  EMAIL
  SMS
  WHATSAPP
  MEETING // Yüz yüze görüşme
  NOTE // İç not
}

enum CommunicationDirection {
  INBOUND // Gelen
  OUTBOUND // Giden
}

// Müşteri ile yapılan tüm iletişim kayıtları (arama, e-posta, WhatsApp...)
model CommunicationLog {
  id String @id @default(cuid()) @map("_id")

  channel     CommunicationChannel
  direction   CommunicationDirection @default(OUTBOUND)
  subject     String?
  content     String?
  occurredAt  DateTime               @default(now())
  durationSec Int? // Arama süresi (saniye)
  outcome     String? // Görüşme sonucu

  clientId String?
  client   PropertyClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  agentId String? // İletişimi yapan danışman
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  listingId String? // İlgili ilan
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agencyId])
  @@index([clientId])
  @@index([agentId])
  @@map("communication-logs")
}

enum NotificationTypeGayrimenkul {
  INFO
  WARNING
  SUCCESS
  REMINDER
  TASK
}

// Kullanıcıya özel bildirim (okundu/okunmadı takipli)
model AgencyNotification {
  id String @id @default(cuid()) @map("_id")

  type    NotificationTypeGayrimenkul @default(INFO)
  title   String
  message String
  link    String?
  isRead  Boolean                     @default(false)
  readAt  DateTime?

  recipientUserId String? // Hedef User id (esnek)

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  clientId String?
  client   PropertyClient? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agencyId])
  @@index([recipientUserId])
  @@index([isRead])
  @@map("agency-notifications")
}

// ============================================================
// ===============  GELİŞMİŞ ERP: AUDIT TRAIL  ===============
// ============================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  STATUS_CHANGE
  OTHER
}

// Kayıt bazlı değişiklik geçmişi (kim, ne zaman, neyi değiştirdi)
model AgencyAuditLog {
  id String @id @default(cuid()) @map("_id")

  action   AuditAction
  entity   String // Model adı: "PropertyOffer", "AgencyInvoice" vb.
  entityId String? // Etkilenen kaydın id'si
  summary  String // İnsan-okur özet
  changes  Json? // Önce/sonra alan farkları (opsiyonel)

  userId   String? // İşlemi yapan kullanıcı
  userName String? // Snapshot ad
  userRole String? // Snapshot rol

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agencyId])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@map("agency-audit-logs")
}

//Real Estate ERP

// ============================================================
// ===============  REAL ESTATE CRM (ERP üstü)  ===============
// ============================================================

enum LeadStatus {
  OPEN // Açık (hatta aktif)
  WON // Kazanıldı
  LOST // Kaybedildi
}

enum LeadSource {
  WEBSITE // Web sitesi
  PORTAL // Sahibinden / Hepsiemlak vb.
  PHONE // Telefon
  WALK_IN // Ofise gelen
  REFERRAL // Tavsiye
  SOCIAL_MEDIA // Sosyal medya
  ADVERTISEMENT // Reklam
  EMAIL_CAMPAIGN // E-posta kampanyası
  PARTNER // İş ortağı
  OTHER
}

enum LeadTemperature {
  HOT // Sıcak
  WARM // Ilık
  COLD // Soğuk
}

enum CrmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CrmActivityType {
  NOTE // Not
  CALL // Telefon görüşmesi
  EMAIL // E-posta
  WHATSAPP // WhatsApp
  MEETING // Toplantı
  VISIT // Mülk gezisi
  SMS
  STAGE_CHANGE // Aşama değişikliği (otomatik)
  TASK // Görev (otomatik)
  WON // Kazanıldı (otomatik)
  LOST // Kaybedildi (otomatik)
  CREATED // Oluşturuldu (otomatik)
  FILE // Dosya
}

// Satış hattı (örn. "Satılık Pipeline", "Kiralık Pipeline")
model CrmPipeline {
  id          String       @id @default(cuid()) @map("_id")
  name        String
  description String?
  listingType ListingType? // Bu hat hangi ilan türü için (opsiyonel)
  color       String       @default("#6366f1")
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  order       Int          @default(0)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  stages CrmStage[]
  leads  Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@map("crm-pipelines")
}

// Hat aşaması (örn. "Yeni", "İletişim Kuruldu", "Teklif", "Pazarlık")
model CrmStage {
  id          String  @id @default(cuid()) @map("_id")
  name        String
  color       String  @default("#94a3b8")
  order       Int     @default(0)
  probability Int     @default(0) // Kazanma olasılığı (%)
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)
  rottenDays  Int? // Bu kadar gün hareketsiz kalırsa "çürük" sayılır

  pipelineId String
  pipeline   CrmPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId])
  @@map("crm-stages")
}

// Müşteri adayı / Fırsat (Deal)
model Lead {
  id    String @id @default(cuid()) @map("_id")
  title String // Fırsat başlığı, örn. "Kadıköy 3+1 arayan - Ahmet Yılmaz"

  // İletişim bilgileri (henüz Client kaydı olmayabilir)
  contactName  String
  contactEmail String?
  contactPhone String?
  company      String?

  source      LeadSource      @default(OTHER)
  status      LeadStatus      @default(OPEN)
  temperature LeadTemperature @default(WARM)

  // Finansal
  value     Float? // Fırsatın tahmini değeri
  currency  String @default("TRY")
  budgetMin Float?
  budgetMax Float?

  // Talep / eşleştirme kriterleri
  listingType  ListingType?
  propertyType PropertyType?
  city         String?
  district     String?
  roomCount    String?
  requirements String? // Serbest metin talep

  expectedCloseDate DateTime?
  lostReason        String?
  wonAt             DateTime?
  lostAt            DateTime?
  lastActivityAt    DateTime  @default(now())
  position          Int       @default(0) // Aşama içi sıralama
  score             Int       @default(0) // Otomatik lead skoru (0-100)

  tags String[]

  // İlişkiler
  pipelineId String
  pipeline   CrmPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stageId String
  stage   CrmStage @relation(fields: [stageId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Atanan danışman
  agentId   String?
  agentName String?
  agent     Agent?  @relation(fields: [agentId], references: [id])

  // Var olan müşteriye bağlıysa
  clientId String?
  client   PropertyClient? @relation(fields: [clientId], references: [id])

  // İlgilenilen ilana bağlıysa
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  // Pazar yeri ziyaretçisi giriş yapmış bir kullanıcıysa onun hesabı.
  // Müşteriye dönüştürmede e-postaya gerek kalmadan kesin eşleştirme sağlar.
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  activities CrmActivity[]
  tasks      CrmTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([pipelineId, stageId])
  @@index([agentId])
  @@index([userId])
  @@map("crm-leads")
}

// Aktivite / zaman çizelgesi kaydı (not, çağrı, e-posta, aşama değişimi...)
model CrmActivity {
  id      String          @id @default(cuid()) @map("_id")
  type    CrmActivityType
  title   String
  content String?
  meta    Json? // Örn. { fromStage, toStage } veya { duration }

  // Planlı/yapıldı bilgisi (çağrı/toplantı planı için)
  dueAt       DateTime?
  completedAt DateTime?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Aktiviteyi yapan danışman
  agentId   String?
  agentName String?
  agent     Agent?  @relation(fields: [agentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([agencyId])
  @@map("crm-activities")
}

// Görev (takip et, ara, evrak hazırla...)
model CrmTask {
  id          String          @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      CrmTaskStatus   @default(TODO)
  priority    CrmTaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  agentId   String?
  agentName String?
  agent     Agent?  @relation(fields: [agentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([leadId])
  @@index([agentId])
  @@map("crm-tasks")
}

//Sahibinden
// =====================================================================
//  SAHIBINDEN — Classifieds Marketplace (yeni şema, login/register'a bağlı)
// =====================================================================

enum ShListingStatus {
  DRAFT // Taslak
  PENDING // Onay bekliyor
  ACTIVE // Yayında
  PASSIVE // Pasif / yayından kaldırıldı
  SOLD // Satıldı
  REJECTED // Reddedildi
  EXPIRED // Süresi doldu
}

enum ShListingType {
  SALE // Satılık
  RENT // Kiralık
  DAILY_RENT // Günlük Kiralık
  EXCHANGE // Takas
  WANTED // Aranıyor
}

enum ShCurrency {
  TRY
  USD
  EUR
  GBP
}

/// Hiyerarşik kategori ağacı (Emlak > Konut > Satılık Daire ...)
model ShCategory {
  id       String  @id @default(cuid()) @map("_id")
  name     String
  slug     String  @unique
  icon     String?
  order    Int     @default(0)
  featured Boolean @default(false)

  parentId String?
  parent   ShCategory?  @relation("ShCategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children ShCategory[] @relation("ShCategoryTree")

  listings ShListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([featured])
  @@map("sh_categories")
}

/// İlan
model ShListing {
  id          String @id @default(cuid()) @map("_id")
  listingNo   Int    @unique // Sahibinden ilan numarası
  title       String
  slug        String
  description String

  price    Float
  currency ShCurrency @default(TRY)

  type   ShListingType   @default(SALE)
  status ShListingStatus @default(ACTIVE)

  categoryId String
  category   ShCategory @relation(fields: [categoryId], references: [id])

  userId String
  user   User   @relation("ShUserListings", fields: [userId], references: [id], onDelete: Cascade)

  // Kurumsal mağaza / galeri / emlak ofisi (opsiyonel)
  storeId String?
  store   ShStore? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  // İlanı yöneten danışman (opsiyonel)
  agentId String?
  agent   ShAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // İlişkisel lokasyon (opsiyonel — geriye uyum için string alanlar korunur)
  locationId String?
  location   ShLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  city         String?
  district     String?
  neighborhood String?
  address      String?
  latitude     Float?
  longitude    Float?

  images String[] @default([])

  // Emlak medya (gelişmiş)
  floorPlans   String[] @default([]) // Kat planı görselleri
  videoUrl     String? // Video tur (YouTube/Vimeo)
  tourImageUrl String? // 360° panorama görseli

  /// Kategoriye özel özellikler (m², oda sayısı, km, model yılı, vb.)
  attributes Json?

  // Denormalize edilmiş, indeksli filtre/sıralama alanları (attributes'tan türetilir)
  areaGross   Float? // m² brüt — hızlı aralık filtresi + sıralama
  buildingAge Int? // bina yaşı — hızlı aralık filtresi

  // Durum / ticaret seçenekleri
  condition     String? // Sıfır / İkinci El
  isNegotiable  Boolean @default(false) // Pazarlık payı var
  acceptsSwap   Boolean @default(false) // Takasa açık
  securePayment Boolean @default(false) // Güvenli ödeme / kapora

  // Doping bayrakları + bitiş tarihleri
  isUrgent      Boolean   @default(false) // Acil
  isFeatured    Boolean   @default(false) // Öne çıkan
  isShowcase    Boolean   @default(false) // Vitrin
  urgentUntil   DateTime?
  featuredUntil DateTime?
  showcaseUntil DateTime?
  bumpedAt      DateTime? // İlanı güncelle/öne al
  isActive      Boolean   @default(true)

  // İlan yayın (hosting) aboneliği — günlük/haftalık ücretli yayın
  hostingPaidUntil DateTime?
  // Otomatik yenilenen doping aboneliği aktif mi (ilan hep vitrinde/öne çıkanda)
  autoDopingOn     Boolean   @default(false)

  // --- Kısa dönem kiralama (günlük/haftalık rezervasyon) ---
  rentable     Boolean @default(false) // Rezervasyona açık mı
  dailyPrice   Float? // Günlük fiyat
  weeklyPrice  Float? // Haftalık fiyat (günlüğe göre indirimli olabilir)
  monthlyPrice Float? // Aylık fiyat
  cleaningFee  Float? // Temizlik ücreti (tek seferlik)
  rentDeposit  Float? // Güvenlik depozitosu (iade edilebilir)
  minNights    Int? // En az kaç gece
  maxNights    Int? // En çok kaç gece
  maxGuests    Int? // Maksimum misafir
  checkInTime  String? // "14:00"
  checkOutTime String? // "11:00"
  instantBook  Boolean @default(false) // Onaysız anında rezervasyon

  // İptal politikası: FLEXIBLE | MODERATE | STRICT (iade oranını belirler)
  cancellationPolicy  String  @default("MODERATE")
  houseRules          String? // Ev kuralları (sigara/evcil hayvan/parti vb.)
  checkInInstructions String? // Giriş talimatları / anahtar / şifre (onaylı kiracıya gösterilir)
  icalToken           String? // Kiralama takvimi dışa aktarma feed'i (uygulama içinde benzersiz üretilir; çoklu null sorunu için @unique kullanılmaz)

  viewCount     Int @default(0)
  favoriteCount Int @default(0)
  messageCount  Int @default(0)

  contactName  String?
  contactPhone String?
  showPhone    Boolean @default(true)

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  favorites      ShFavorite[]
  messages       ShMessage[]
  reports        ShReport[]
  priceHistory   ShPriceHistory[]
  dopings        ShListingDoping[]
  conversations  ShConversation[]
  recentViews    ShRecentView[]
  reviews        ShReview[]
  appointments   ShViewingAppointment[]
  deposits       ShDeposit[]
  stats          ShListingStat[]
  subscriptions  ShSubscription[]       @relation("ShListingSubscriptions")
  rentalBookings ShRentalBooking[]
  rentalBlocks   ShRentalBlock[]

  @@index([categoryId])
  @@index([userId])
  @@index([storeId])
  @@index([locationId])
  @@index([status])
  @@index([type])
  @@index([city])
  @@index([createdAt])
  @@index([isShowcase])
  @@index([isFeatured])
  @@index([areaGross])
  @@index([buildingAge])
  @@index([latitude])
  @@index([longitude])
  @@map("sh_listings")
}

/// Favoriler
model ShFavorite {
  id        String    @id @default(cuid()) @map("_id")
  userId    String
  user      User      @relation("ShUserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("sh_favorites")
}

enum ShMessageKind {
  TEXT
  IMAGE
  CALL // görüntülü/sesli arama kaydı
  VOICE // sesli mesaj (ses kaydı)
  FILE // dosya/belge (PDF vb.)
}

/// İlan üzerinden mesajlaşma
model ShMessage {
  id        String    @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   ShConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId   String
  sender     User   @relation("ShSentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ShReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  content String
  isRead  Boolean @default(false)

  kind     ShMessageKind @default(TEXT)
  imageUrl String? // IMAGE türü için Cloudinary görsel adresi

  // VOICE türü için: ses kaydı adresi ve süresi
  audioUrl      String?
  audioDuration Int? // saniye

  // FILE türü için: dosya adresi, adı ve boyutu
  fileUrl  String?
  fileName String?
  fileSize Int? // byte

  // CALL türü için: arama sonucu ve süresi
  callOutcome  String? // "answered" | "missed" | "rejected" | "cancelled"
  callDuration Int? // saniye cinsinden konuşma süresi
  callVideo    Boolean @default(true) // görüntülü mü, sesli mi

  editedAt  DateTime?
  deletedAt DateTime?

  // Yanıtla / alıntıla (bir mesaja yanıt)
  replyToId String?
  replyTo   ShMessage?  @relation("ShMsgReply", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   ShMessage[] @relation("ShMsgReply")

  // Reaksiyonlar: [{ userId, emoji }]
  reactions Json?

  // Sabitlenmiş mesaj (konuşma başında gösterilir)
  pinnedAt      DateTime?
  // İletilen mesaj — kaynak mesaj id'si
  forwardedFrom String?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@map("sh_messages")
}

enum ShReportStatus {
  OPEN // İncelenmedi
  REVIEWING // İnceleniyor
  RESOLVED // Çözüldü
  DISMISSED // Reddedildi
}

/// İlan şikayeti
model ShReport {
  id          String         @id @default(cuid()) @map("_id")
  listingId   String
  listing     ShListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("ShUserReports", fields: [userId], references: [id], onDelete: Cascade)
  reason      String
  description String?
  status      ShReportStatus @default(OPEN)
  adminNote   String?
  createdAt   DateTime       @default(now())

  @@index([listingId])
  @@index([status])
  @@map("sh_reports")
}

/// Kayıtlı aramalar
model ShSavedSearch {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  user      User     @relation("ShUserSavedSearches", fields: [userId], references: [id], onDelete: Cascade)
  name      String
  query     Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sh_saved_searches")
}

// =====================================================================
//  SAHIBINDEN — Kurumsal / Gelişmiş modüller
// =====================================================================

enum ShStoreType {
  INDIVIDUAL // Bireysel
  CORPORATE // Kurumsal mağaza
  CAR_GALLERY // Oto galeri
  REAL_ESTATE_OFFICE // Emlak ofisi
  AUTHORIZED_DEALER // Yetkili bayi
}

/// Kurumsal mağaza / galeri / emlak ofisi
model ShStore {
  id            String      @id @default(cuid()) @map("_id")
  ownerId       String
  owner         User        @relation("ShStoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  slug          String      @unique
  type          ShStoreType @default(CORPORATE)
  logo          String?
  banner        String?
  about         String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?
  taxOffice     String?
  taxNumber     String?
  memberSince   DateTime    @default(now())
  isVerified    Boolean     @default(false)
  rating        Float       @default(0)
  reviewCount   Int         @default(0)
  followerCount Int         @default(0)

  // Pro mağaza aboneliği (tekrarlayan)
  isPro     Boolean   @default(false)
  proUntil  DateTime?
  proPlanId String?

  listings      ShListing[]
  reviews       ShReview[]
  agents        ShAgent[]
  subscriptions ShSubscription[] @relation("ShStoreSubscriptions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([type])
  @@map("sh_stores")
}

enum ShLocationType {
  CITY // İl
  DISTRICT // İlçe
  NEIGHBORHOOD // Mahalle
}

/// İl / İlçe / Mahalle hiyerarşisi
model ShLocation {
  id        String         @id @default(cuid()) @map("_id")
  name      String
  slug      String
  type      ShLocationType
  plateCode Int? // İl plaka kodu
  parentId  String?
  parent    ShLocation?    @relation("ShLocationTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  ShLocation[]   @relation("ShLocationTree")
  listings  ShListing[]

  createdAt DateTime @default(now())

  @@index([parentId])
  @@index([type])
  @@map("sh_locations")
}

enum ShAttrType {
  TEXT
  NUMBER
  SELECT
  BOOLEAN
}

/// Dinamik (admin tanımlı) kategori özellik şeması — filtreleri data-driven yapar
model ShCategoryAttribute {
  id         String     @id @default(cuid()) @map("_id")
  categoryId String // Üst kategori slug'ına göre çözümlenir
  key        String
  label      String
  type       ShAttrType @default(TEXT)
  options    String[]   @default([])
  unit       String?
  filterable Boolean    @default(false)
  required   Boolean    @default(false)
  order      Int        @default(0)

  createdAt DateTime @default(now())

  @@index([categoryId])
  @@map("sh_category_attributes")
}

enum ShDopingType {
  SHOWCASE // Vitrin
  FEATURED // Öne çıkan
  URGENT // Acil
  BUMP // Üste taşı
  BOLD // Kalın yazı
}

/// Doping paketleri (ücretli öne çıkarma)
model ShDopingPackage {
  id           String       @id @default(cuid()) @map("_id")
  name         String
  type         ShDopingType
  durationDays Int          @default(7)
  price        Float
  currency     ShCurrency   @default(TRY)
  active       Boolean      @default(true)
  order        Int          @default(0)

  dopings ShListingDoping[]

  createdAt DateTime @default(now())

  @@map("sh_doping_packages")
}

enum ShDopingStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

/// Bir ilana uygulanan doping satın alımı
model ShListingDoping {
  id        String          @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  packageId String
  package   ShDopingPackage @relation(fields: [packageId], references: [id])
  userId    String
  user      User            @relation("ShUserDopings", fields: [userId], references: [id], onDelete: Cascade)
  paymentId String?
  payment   ShPayment?      @relation(fields: [paymentId], references: [id])

  status    ShDopingStatus @default(ACTIVE)
  startsAt  DateTime       @default(now())
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([userId])
  @@map("sh_listing_dopings")
}

enum ShPaymentType {
  LISTING_FEE
  DOPING
  STORE_SUBSCRIPTION
  DEPOSIT
  WALLET_TOPUP // cüzdana para yükleme
  SUBSCRIPTION // tekrarlayan abonelik tahsilatı (ilk + yenileme)
}

enum ShPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/// Ödeme kayıtları (doping / ilan ücreti / mağaza aboneliği)
model ShPayment {
  id       String          @id @default(cuid()) @map("_id")
  userId   String
  user     User            @relation("ShUserPayments", fields: [userId], references: [id], onDelete: Cascade)
  amount   Float
  currency ShCurrency      @default(TRY)
  type     ShPaymentType   @default(DOPING)
  status   ShPaymentStatus @default(PAID)
  provider String? // iyzico / stripe / paypal / wallet
  refId    String? // sağlayıcı işlem no (idempotency anahtarı)
  meta     Json?

  // İade takibi (kısmi iade destekli)
  refundedAmount Float     @default(0)
  refundedAt     DateTime?
  refundRef      String? // sağlayıcı iade işlem no

  // Tekrarlayan abonelik tahsilatıysa hangi aboneliğe ait
  subscriptionId String?
  subscription   ShSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  dopings        ShListingDoping[]
  deposits       ShDeposit[]
  walletTxns     ShWalletTxn[]
  rentalBookings ShRentalBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([refId])
  @@index([subscriptionId])
  @@map("sh_payments")
}

/// Mesajlaşma konuşması (ilan + alıcı + satıcı)
model ShConversation {
  id        String    @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User      @relation("ShConvBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User      @relation("ShConvSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  lastMessageAt  DateTime @default(now())
  buyerArchived  Boolean  @default(false)
  sellerArchived Boolean  @default(false)
  buyerUnread    Int      @default(0)
  sellerUnread   Int      @default(0)

  // "yazıyor..." göstergesi için son tuş zamanları
  buyerTypingAt  DateTime?
  sellerTypingAt DateTime?

  messages ShMessage[]

  createdAt DateTime @default(now())

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("sh_conversations")
}

/// WebRTC görüntülü arama sinyalleşmesi (offer/answer/ice + arama yaşam döngüsü).
/// Sunucu tarafında kalıcı bir WebSocket olmadığı için DB üzerinden polling ile taşınır.
model ShCallSignal {
  id        String  @id @default(cuid()) @map("_id")
  callId    String // bir arama oturumunu gruplar
  listingId String
  fromId    String
  toId      String
  // "ring" | "offer" | "answer" | "ice" | "accept" | "reject" | "end" | "busy" | "cancel"
  type      String
  payload   String? // JSON: SDP veya ICE candidate
  video     Boolean @default(true)
  consumed  Boolean @default(false) // karşı taraf işledikten sonra true

  createdAt DateTime @default(now())

  @@index([toId, consumed])
  @@index([callId])
  @@index([createdAt])
  @@map("sh_call_signals")
}

enum ShNotificationType {
  NEW_MESSAGE
  LISTING_APPROVED
  LISTING_REJECTED
  PRICE_DROP
  FAVORITE_SOLD
  SAVED_SEARCH_MATCH
  DOPING_EXPIRING
}

/// Bildirimler
model ShNotification {
  id        String             @id @default(cuid()) @map("_id")
  userId    String
  user      User               @relation("ShUserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      ShNotificationType
  title     String
  body      String?
  link      String?
  listingId String?
  isRead    Boolean            @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("sh_notifications")
}

/// Satıcı / mağaza değerlendirmesi
model ShReview {
  id           String     @id @default(cuid()) @map("_id")
  authorId     String
  author       User       @relation("ShReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User       @relation("ShReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  storeId      String?
  store        ShStore?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  listingId    String?
  listing      ShListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  rating       Int // 1-5
  comment      String?

  // Hangi rezervasyon/randevu sonrası bırakıldı (varsa)
  bookingId     String?
  appointmentId String?

  createdAt DateTime @default(now())

  @@index([targetUserId])
  @@index([storeId])
  @@index([bookingId])
  @@index([appointmentId])
  @@map("sh_reviews")
}

/// Fiyat değişim geçmişi
model ShPriceHistory {
  id        String     @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  oldPrice  Float
  newPrice  Float
  currency  ShCurrency @default(TRY)
  createdAt DateTime   @default(now())

  @@index([listingId])
  @@map("sh_price_history")
}

/// Son baktığın ilanlar
model ShRecentView {
  id        String    @id @default(cuid()) @map("_id")
  userId    String
  user      User      @relation("ShUserRecentViews", fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewedAt  DateTime  @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@map("sh_recent_views")
}

// =====================================================================
//  SAHIBINDEN — Emlak (gelişmiş): randevu + kapora
// =====================================================================

enum ShAppointmentStatus {
  PENDING // Talep edildi
  CONFIRMED // Onaylandı
  REJECTED // Reddedildi
  CANCELLED // İptal
  COMPLETED // Gerçekleşti
}

enum ShAppointmentMode {
  FACE_TO_FACE // Yüz yüze gezme (onaylı)
  VIDEO // Görüntülü (kameradan) görüşme
}

/// Emlak gezme / görüntülü görüşme randevusu
model ShViewingAppointment {
  id          String              @id @default(cuid()) @map("_id")
  listingId   String
  listing     ShListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                @relation("ShApptRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User                @relation("ShApptOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  durationMin Int                 @default(30) // tahmini süre (dk)
  mode        ShAppointmentMode   @default(FACE_TO_FACE)
  note        String?
  phone       String?
  status      ShAppointmentStatus @default(PENDING)

  // Kiracının önerdiği alternatif/sıralı saatler: ["2026-07-01T10:00:00Z", ...]
  // Ev sahibi onaylarken bunlardan birini seçebilir.
  alternativeSlots Json?

  // Randevu sonrası karşılıklı değerlendirme (1-5)
  ratingByRequester Int?
  ratingByOwner     Int?
  reviewByRequester String?
  reviewByOwner     String?

  // Görüntülü görüşme izleme
  callStartedAt DateTime?
  callEndedAt   DateTime?

  // Yeniden planlama (karşı-teklif): bir taraf yeni saat önerir, diğeri kabul/ret eder.
  proposedAt   DateTime?
  proposedById String?

  // Otomatik hatırlatma gönderildi mi (cron)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([requesterId])
  @@index([ownerId])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
  @@map("sh_viewing_appointments")
}

/// İlan sahibinin haftalık randevu müsaitliği (Calendly tarzı slot üretimi için)
model ShAvailability {
  id           String @id @default(cuid()) @map("_id")
  userId       String @unique
  timezone     String @default("Europe/Istanbul")
  slotMinutes  Int    @default(30) // her randevu/slot süresi (dk)
  // Haftalık kurallar: [{ day: 0-6 (0=Pazar), start: "10:00", end: "18:00" }]
  rules        Json   @default("[]")
  // Tek seferlik kapalı günler: ["2026-07-01", ...]
  blockedDates Json   @default("[]")
  leadHours    Int    @default(2) // en erken kaç saat sonrasına randevu
  maxDaysAhead Int    @default(30) // kaç gün ileriye kadar açık

  // Otomatik onay: ilgili moddaki talepler ev sahibi onayı beklemeden CONFIRMED olur
  autoConfirmVideo      Boolean @default(false)
  autoConfirmFaceToFace Boolean @default(false)
  // Günlük randevu kotası (0 = sınırsız)
  maxPerDay             Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sh_availability")
}

enum ShDepositStatus {
  PENDING // Ödeme bekliyor
  HELD // Ödendi / emanette
  RELEASED // Satıcıya aktarıldı
  REFUNDED // İade edildi
  DISPUTED // Anlaşmazlık açıldı (admin çözecek)
  CANCELLED // İptal
}

/// Günlük ilan istatistiği (görüntülenme/favori trendi)
model ShListingStat {
  id        String    @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date      String // yyyy-mm-dd
  views     Int       @default(0)
  favorites Int       @default(0)

  @@unique([listingId, date])
  @@index([listingId])
  @@map("sh_listing_stats")
}

/// Kullanıcı engelleme (kara liste)
model ShUserBlock {
  id        String   @id @default(cuid()) @map("_id")
  blockerId String
  blocker   User     @relation("ShBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("ShBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@map("sh_user_blocks")
}

/// Emlak danışmanı (ofis/mağaza altında)
model ShAgent {
  id      String  @id @default(cuid()) @map("_id")
  storeId String
  store   ShStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String
  title   String?
  phone   String?
  email   String?
  photo   String?
  bio     String?

  listings ShListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@map("sh_agents")
}

/// Kapora / ön ödeme (escrow-lite)
model ShDeposit {
  id        String          @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User            @relation("ShDepositBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  amount    Float
  currency  ShCurrency      @default(TRY)
  status    ShDepositStatus @default(PENDING)
  paymentId String?
  payment   ShPayment?      @relation(fields: [paymentId], references: [id])

  // Anlaşmazlık / serbest bırakma izleme
  disputeReason String?
  disputedById  String?
  releasedAt    DateTime?
  refundedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@map("sh_deposits")
}

// ===========================================================================
//  TEKRARLAYAN ÖDEME / ABONELİK / CÜZDAN
//  Dört konu tek motorda: "interval'i (gün/hafta/ay) olan bir Plan'a abonelik".
// ===========================================================================

enum ShBillingInterval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum ShPlanKind {
  STORE_PRO // Pro mağaza üyeliği
  DOPING_AUTO // Otomatik yenilenen doping (ilan hep vitrinde/öne çıkanda)
  LISTING_HOSTING // İlan yayın ücreti (günlük/haftalık)
}

/// Abonelik planı kataloğu (admin tanımlı). Stripe/PayPal fiyatlarına eşlenir.
model ShPlan {
  id            String            @id @default(cuid()) @map("_id")
  name          String
  slug          String            @unique
  kind          ShPlanKind
  interval      ShBillingInterval @default(WEEK)
  intervalCount Int               @default(1) // örn. her 2 haftada bir
  price         Float
  currency      ShCurrency        @default(TRY)
  trialDays     Int               @default(0)
  features      String[]          @default([]) // pazarlama maddeleri
  limits        Json? // { maxListings: 50, maxPhotos: 30, ... }
  dopingType    ShDopingType? // DOPING_AUTO planları için hangi doping
  badge         String? // "Popüler" / "En Avantajlı"
  active        Boolean           @default(true)
  order         Int               @default(0)

  // Sağlayıcıda önceden oluşturulmuş tekrarlayan fiyat/plan kimlikleri
  stripePriceId String?
  paypalPlanId  String?

  subscriptions ShSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@map("sh_plans")
}

enum ShSubStatus {
  PENDING // checkout başladı, ilk ödeme bekleniyor
  TRIALING
  ACTIVE
  PAST_DUE // ödeme başarısız — grace dönemi
  CANCELED // dönem sonunda bitecek / bitti
  EXPIRED
}

/// Canlı abonelik kaydı (Stripe/PayPal/cüzdan ile yenilenir).
model ShSubscription {
  id     String     @id @default(cuid()) @map("_id")
  userId String
  user   User       @relation("ShUserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  planId String
  plan   ShPlan     @relation(fields: [planId], references: [id])
  kind   ShPlanKind

  // Hedef (kind'a göre opsiyonel)
  storeId   String?
  store     ShStore?   @relation("ShStoreSubscriptions", fields: [storeId], references: [id], onDelete: Cascade)
  listingId String?
  listing   ShListing? @relation("ShListingSubscriptions", fields: [listingId], references: [id], onDelete: Cascade)

  status             ShSubStatus @default(PENDING)
  provider           String // "stripe" | "paypal" | "wallet"
  providerSubId      String? // stripe sub_… / paypal I-…
  providerCustomerId String?

  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  // Cüzdan ile otomatik yenileme
  autoRenew      Boolean @default(true)
  failedAttempts Int     @default(0)

  payments ShPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerSubId])
  @@index([listingId])
  @@index([storeId])
  @@map("sh_subscriptions")
}

enum ShWalletTxnType {
  TOPUP // para yükleme
  SPEND // harcama
  REFUND // iade
  BONUS // promosyon/hediye
}

/// Kullanıcı ön ödemeli bakiyesi.
model ShWallet {
  id       String     @id @default(cuid()) @map("_id")
  userId   String     @unique
  user     User       @relation("ShUserWallet", fields: [userId], references: [id], onDelete: Cascade)
  balance  Float      @default(0)
  currency ShCurrency @default(TRY)

  // Bakiye eşiğin altına düşünce otomatik yükleme (saklı kartla)
  autoTopup          Boolean @default(false)
  autoTopupThreshold Float   @default(0)
  autoTopupAmount    Float   @default(0)

  txns ShWalletTxn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sh_wallets")
}

/// Cüzdan defteri (her hareket bir satır; bakiye türetilebilir + denetlenebilir).
model ShWalletTxn {
  id           String          @id @default(cuid()) @map("_id")
  walletId     String
  wallet       ShWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation("ShUserWalletTxns", fields: [userId], references: [id], onDelete: Cascade)
  type         ShWalletTxnType
  amount       Float // +yükleme / -harcama
  balanceAfter Float
  currency     ShCurrency      @default(TRY)
  description  String?
  refType      String? // "doping" | "subscription" | "topup" | "deposit"
  refId        String?
  paymentId    String?
  payment      ShPayment?      @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([userId])
  @@map("sh_wallet_txns")
}

// ===========================================================================
//  KISA DÖNEM KİRALAMA / REZERVASYON (günlük / haftalık)
// ===========================================================================

enum ShRentalUnit {
  DAY
  WEEK
  MONTH
}

enum ShBookingStatus {
  PENDING // Talep edildi, ödeme/onay bekliyor
  AWAITING_APPROVAL // Ödendi, ev sahibi onayı bekleniyor
  CONFIRMED // Onaylandı / kesinleşti
  REJECTED // Ev sahibi reddetti (iade)
  CANCELLED // İptal edildi
  COMPLETED // Konaklama tamamlandı
  EXPIRED // Süresi doldu (ödenmedi)
}

/// Bir ilana ait kiralama rezervasyonu (tarih aralığı + fiyat dökümü).
model ShRentalBooking {
  id        String    @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  renterId  String
  renter    User      @relation("ShBookingRenter", fields: [renterId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User      @relation("ShBookingOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Tarih aralığı (UTC gün başlangıcı). endDate = çıkış günü (dahil değil).
  startDate DateTime
  endDate   DateTime
  unit      ShRentalUnit @default(DAY)
  nights    Int // gece/gün sayısı
  guests    Int          @default(1)

  // Fiyat dökümü
  pricePerUnit Float
  subtotal     Float
  cleaningFee  Float      @default(0)
  serviceFee   Float      @default(0)
  discount     Float      @default(0)
  deposit      Float      @default(0) // güvenlik depozitosu (iade edilebilir)
  totalAmount  Float
  currency     ShCurrency @default(TRY)

  status ShBookingStatus @default(PENDING)

  note         String?
  contactPhone String?
  cancelReason String?

  // Tarih değişikliği önerisi (kiracı veya ev sahibi önerir, diğeri onaylar)
  proposedStartDate   DateTime?
  proposedEndDate     DateTime?
  proposedById        String?
  proposedTotalAmount Float?

  // İade + değerlendirme izleme
  refundedAmount Float   @default(0)
  renterReviewed Boolean @default(false)
  ownerReviewed  Boolean @default(false)

  paymentId String?
  payment   ShPayment? @relation(fields: [paymentId], references: [id])
  depositId String? // ShDeposit (güvenlik depozitosu emaneti)

  confirmedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([renterId])
  @@index([ownerId])
  @@index([status])
  @@index([listingId, startDate, endDate])
  @@map("sh_rental_bookings")
}

/// Ev sahibinin manuel kapattığı (müsait olmayan) tarih aralıkları.
model ShRentalBlock {
  id        String    @id @default(cuid()) @map("_id")
  listingId String
  listing   ShListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  reason    String?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([listingId, startDate, endDate])
  @@map("sh_rental_blocks")
}

/// Web Push aboneliği (tarayıcı bildirimleri için). İlişkisiz — userId scalar.
model ShPushSub {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  ua        String? // tarayıcı bilgisi (opsiyonel)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sh_push_subs")
}










// ============================================================
// ÖZCAN EMLAK SİTESİ — Temiz, büyümeye uygun emlak modülü
// (Mevcut Property / PropertyRealEstate / Sahibinden'den bağımsız)
// ============================================================

enum EmlakListingType {
  SATILIK
  KIRALIK
}

enum EmlakCategory {
  KONUT // Daire, villa, müstakil ev vb.
  ISYERI // Dükkan, ofis, depo
  ARSA // Arsa / tarla
  BINA // Komple bina
  DEVREMULK // Devremülk
  TURISTIK // Turistik tesis
}

enum EmlakStatus {
  TASLAK // Henüz yayınlanmadı
  YAYINDA // Sitede görünür
  SATILDI // Satıldı
  KIRALANDI // Kiralandı
  PASIF // Arşivlendi / gizlendi
}

enum EmlakHeating {
  YOK
  SOBA
  KOMBI_DOGALGAZ
  KAT_KALORIFERI
  MERKEZI
  MERKEZI_PAY_OLCER
  KLIMA
  YERDEN_ISITMA
}

enum EmlakUsageStatus {
  BOS
  KIRACILI
  MULK_SAHIBI
}

// Ana ilan modeli
model EmlakListing {
  id String @id @default(cuid()) @map("_id")

  // Sahip / danışman (şimdilik sadece Özcan)
  userId String
  user   User   @relation("EmlakUserListings", fields: [userId], references: [id], onDelete: Cascade)

  // Temel bilgiler
  title       String
  slug        String           @unique
  description String
  listingType EmlakListingType
  category    EmlakCategory    @default(KONUT)
  status      EmlakStatus      @default(YAYINDA)

  // Fiyat
  price    Float
  currency String @default("TRY")

  // Konum
  city         String // İl
  district     String? // İlçe
  neighborhood String? // Mahalle
  address      String?
  latitude     Float?
  longitude    Float?

  // Konut özellikleri
  rooms       String? // "3+1"
  grossArea   Float? // Brüt m²
  netArea     Float? // Net m²
  bathrooms   Int?
  floor       String? // Bulunduğu kat
  totalFloors Int? // Toplam kat
  buildingAge String? // Bina yaşı
  heating     EmlakHeating     @default(YOK)
  furnished   Boolean          @default(false)
  balcony     Boolean          @default(false)
  inSite      Boolean          @default(false) // Site içerisinde
  usageStatus EmlakUsageStatus @default(BOS)
  dues        Float? // Aidat
  deposit     Float? // Depozito (kiralık)

  // Medya
  coverImage String?
  images     EmlakImage[]
  features   String[] // Özellikler (otopark, asansör, eşyalı vb.)

  // İletişim
  contactName  String
  contactPhone String
  contactEmail String?

  // Meta
  isFeatured Boolean        @default(false)
  viewCount  Int            @default(0)
  inquiries  EmlakInquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingType])
  @@index([category])
  @@index([status])
  @@index([city])
  @@index([userId])
  @@map("emlak_listings")
}

// İlan görselleri
model EmlakImage {
  id        String       @id @default(cuid()) @map("_id")
  listingId String
  listing   EmlakListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([listingId])
  @@map("emlak_images")
}

// İletişim / talep formları
model EmlakInquiry {
  id        String       @id @default(cuid()) @map("_id")
  listingId String
  listing   EmlakListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  message   String
  isRead    Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([listingId])
  @@index([isRead])
  @@map("emlak_inquiries")
}







// ============================================================
// Shop - Tek ürünlük (single-product) e-ticaret
// Bağımsız, kendine ait modeller. Diğer modellerle coupling yok.
// ============================================================

// Shop'a özel rol enum'u. Paylaşılan RoleShop'tan ayrı tutulur ki
// mağaza yetkilendirmesi diğer modüllerden bağımsız kalsın.
enum ShopNewRole {
  CUSTOMER // müşteri (satın alma)
  ADMIN    // yönetici (tam yetki)
  SELLER   // satıcı (ürün/sipariş yönetimi)
}

model ShopProduct {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  slug        String   @unique
  description String
  price       Float
  oldPrice    Float?
  currency    String   @default("TRY")
  images      String[]
  features    String[]
  stock       Int      @default(0)
  rating      Float    @default(0)
  numReviews  Int      @default(0)
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders  ShopOrder[]  @relation("ShopProductToOrder")
  reviews ShopReview[] @relation("ShopProductToReview")

  @@map("shop_products")
}

// Mağaza genel ayarları (tek satır). Puan/yorum özelliklerini aç/kapat.
model ShopSettings {
  id             String   @id @default(cuid()) @map("_id")
  ratingsEnabled Boolean  @default(true) // ürüne puan verilebilsin mi
  reviewsEnabled Boolean  @default(true) // ürüne yorum yapılabilsin mi
  updatedAt      DateTime @updatedAt

  @@map("shop_settings")
}

// İndirim kuponu — admin oluşturur, alıcı sepette/checkout'ta kod girerek uygular.
model ShopCoupon {
  id   String @id @default(cuid()) @map("_id")
  code String @unique // büyük harfe normalize edilir (ör. HOSGELDIN10)

  // "percentage" (yüzde) | "fixed" (sabit tutar)
  type  String
  value Float // percentage için % (ör. 10), fixed için tutar (ör. 50)

  // fixed indirim ve minCartTotal bu para biriminde saklanır; checkout'ta çevrilir
  currency String @default("TRY")

  minCartTotal Float? // kupon için gereken minimum sepet toplamı (kupon para biriminde)
  maxUses      Int? // toplam kullanım limiti (null = sınırsız)
  usedCount    Int    @default(0) // şu ana kadar kaç kez kullanıldı
  expiresAt    DateTime? // son kullanma (null = süresiz)
  active       Boolean   @default(true) // silmeden geçici kapatma

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shop_coupons")
}

// Ürün puanı + yorumu. Giriş yapmış kullanıcı ürün başına tek yorum bırakır.
model ShopReview {
  id        String      @id @default(cuid()) @map("_id")
  productId String
  product   ShopProduct @relation("ShopProductToReview", fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("UserToShopReview", fields: [userId], references: [id], onDelete: Cascade)

  authorName String
  rating     Int    // 1-5
  comment    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("shop_reviews")
}

// Mağaza blog yazıları — admin oluşturur, ziyaretçi okur.
model ShopBlog {
  id         String  @id @default(cuid()) @map("_id")
  title      String
  slug       String  @unique
  excerpt    String
  content    String
  coverImage String?
  published  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shop_blogs")
}

model ShopOrder {
  id         String  @id @default(cuid()) @map("_id")
  productId  String
  product    ShopProduct @relation("ShopProductToOrder", fields: [productId], references: [id])

  // Giriş yapmış üyeye bağlı sipariş (misafir siparişlerde null kalır)
  userId String?
  user   User?   @relation("UserToShopOrder", fields: [userId], references: [id])

  quantity   Int    @default(1)
  unitPrice  Float
  totalPrice Float

  customerName String
  email        String
  phone        String
  address      String
  city         String
  note         String?

  status String @default("PENDING") // PENDING | PAID | PROCESSING | SHIPPED | DELIVERED | CANCELLED

  // Ödeme yöntemi: stripe | paypal | cod_cash (kapıda nakit) | cod_card (kapıda kart)
  paymentMethod String @default("stripe")
  // Siparişin alındığı / ücretlendirildiği para birimi (TRY | USD | EUR)
  currency String @default("TRY")

  // Uygulanan indirim kuponu (varsa). discountAmount bu satıra düşen indirim payıdır (sipariş para biriminde).
  // totalPrice zaten indirim düşülmüş NET tutardır.
  discountCode   String?
  discountAmount Float   @default(0)

  // Kargo takip bilgileri (ürün sahibi/yönetici doldurur, alıcı takip eder)
  trackingNumber String?
  cargoCompany   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("shop_orders")
}

// Mağaza "Bize Ulaşın" mesajları — alıcı/ziyaretçi gönderir, admin panelinde görünür.
model ShopContactMessage {
  id       String  @id @default(cuid()) @map("_id")
  fullName String
  email    String
  phone    String?
  subject  String
  message  String

  // NEW (yeni) | READ (okundu) | REPLIED (yanıtlandı)
  status String @default("NEW")

  // Giriş yapmış kullanıcı gönderdiyse bağlanır (misafirde null)
  userId String?
  user   User?   @relation("UserToShopContactMessage", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("shop_contact_messages")
}

// Alıcının kayıtlı teslimat adresleri — sipariş verirken seçilebilir.
model ShopAddress {
  id     String @id @default(cuid()) @map("_id")
  userId String
  user   User   @relation("UserToShopAddress", fields: [userId], references: [id], onDelete: Cascade)

  title      String // "Ev" / "İş" gibi etiket
  fullName   String
  phone      String
  address    String
  city       String
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("shop_addresses")
}

// Mağaza newsletter aboneleri — footer formundan e-posta toplanır.
model ShopNewsletterSubscriber {
  id    String @id @default(cuid()) @map("_id")
  email String @unique

  // Giriş yapmış kullanıcı abone olduysa bağlanır (misafirde null)
  userId String?
  user   User?   @relation("UserToShopNewsletter", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("shop_newsletter_subscribers")
}




// ————————————————————————————————————————————————————————————
// INVENIMUS — venture studio landing sayfası & admin paneli modelleri.
// MongoDB (additive). Ana User modeline dokunmaz; bağımsız koleksiyonlar.
// ————————————————————————————————————————————————————————————


// Invenimus venture studio admin paneli yetki rolleri (hiyerarşik).
// ADMIN  > EDITOR > VIEWER
//  - ADMIN : tüm içerik + başvurular + kullanıcı/rol yönetimi
//  - EDITOR: içerik (CMS/kadro) + gelen başvuruların yönetimi (rol yönetimi YOK)
//  - VIEWER: yalnızca görüntüleme (salt-okunur)
enum InvenimusRole {
  ADMIN
  EDITOR
  VIEWER
}


// "Fikrini anlat" iletişim formundan gelen başvurular.
model InvenimusLead {
  id      String  @id @default(cuid()) @map("_id")
  name    String
  email   String
  idea    String
  // NEW (yeni) | READ (okundu) | CONTACTED (iletişime geçildi) | ARCHIVED (arşiv)
  status  String  @default("NEW")
  locale  String  @default("tr")
  source  String  @default("contact") // contact | hero
  notes   String? // admin iç notu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("messta_leads")
}

// Yatırımcı eşleştirme formundan gelen başvurular (kurucu veya yatırımcı).
model InvenimusInvestorApplication {
  id       String  @id @default(cuid()) @map("_id")
  name     String
  email    String
  company  String?
  // founder | investor
  audience String  @default("founder")
  stage    String? // pre-seed, seed, series A ...
  ticket   String? // tur / bilet büyüklüğü
  message  String?
  // NEW | REVIEWING | MATCHED | REJECTED | ARCHIVED
  status   String  @default("NEW")
  locale   String  @default("tr")
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([audience])
  @@index([createdAt])
  @@map("messta_investor_applications")
}

// Kadromuz bölümü — admin panelinden yönetilen ekip üyeleri.
model InvenimusTeamMember {
  id        String  @id @default(cuid()) @map("_id")
  name      String
  // Rol/başlık — 3 dilde JSON string ({"tr":"","en":"","de":""}) olarak saklanır.
  role      String
  bio       String
  avatarUrl String?
  linkedin  String?
  twitter   String?
  order     Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("messta_team_members")
}

// Genel site içeriği (CMS): portföy/ventures, hizmetler, referanslar, SSS.
// kind ile ayrışır; çok dilli metinler JSON string olarak title/body içinde tutulur.
model InvenimusContentItem {
  id        String  @id @default(cuid()) @map("_id")
  // venture | service | testimonial | faq
  kind      String
  // JSON string: {"tr":"...","en":"...","de":"..."}
  title     String
  body      String  @default("{}")
  // ek alanlar (yıl, renk, tag, rol, metrik...) JSON string olarak
  meta      String  @default("{}")
  order     Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, order])
  @@map("messta_content_items")
}

// Landing sayfası bölüm CMS'i (overlay). Her key bir bölüme karşılık gelir
// (hero, stats, services, process, marketing, investors, features, ventures,
// testimonials, faq, contact, footer, seo). data = tüm bölüm yükü JSON string:
// çok dilli alanlar {"tr","en","de"} objesi, listeler dizi olarak. Landing render'ında
// statik sözlüğün üstüne yayılır; boşsa/kayıt yoksa statik içeriğe düşer.
model InvenimusSection {
  id        String  @id @default(cuid()) @map("_id")
  key       String  @unique
  data      String  @default("{}")
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messta_sections")
}









// ═══════════════════════════════════════════════════════════════════════════
//  CEYHUN AĞABEY — Vaaz / İçerik / Biblical Turizm / Eğitim / Online Dua platformu
//  Tüm modeller bağımsız koleksiyonlardır (User'a zorunlu ilişki yok).
//  Çok dilli alanlar {"tr","en","de"} JSON string olarak saklanır (mevcut desen).
// ═══════════════════════════════════════════════════════════════════════════


// Ceyhun Ağabey platformu yetki rolleri — iki rol.
//  OWNER  : tam yetki — admin paneli + içerik, tur, dua, bağış, kullanıcı yönetimi
//  VIEWER : sıradan üye — yalnızca admin olmayan (herkese açık) sayfalar; panele giremez
//  Yeni kaydolan her kullanıcı varsayılan olarak VIEWER olur.
enum CeyhunRole {
  OWNER
  VIEWER
}

/// Site/kişi profili — tek kayıt (key="main"). Ana sayfa hero + hakkında + iletişim.
model CeyhunProfile {
  id        String   @id @default(cuid()) @map("_id")
  key       String   @unique @default("main")
  name      String   @default("Ceyhun")
  title     String   @default("{}") // ünvan (çok dilli)
  tagline   String   @default("{}") // hero alt başlık (çok dilli)
  bio       String   @default("{}") // hakkında (HTML, çok dilli)
  about     String   @default("{}") // Hakkımızda sayfası (zengin HTML, resimli, çok dilli)
  avatarUrl String?
  coverUrl  String?
  email     String?
  phone     String?
  whatsapp  String?
  location  String?
  socials   String   @default("{}") // {youtube,instagram,facebook,x} JSON
  verses    String   @default("[]") // öne çıkan ayetler (JSON dizi)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ceyhun_profile")
}

/// Yazı / makale (blog). body zengin HTML, çok dilli.
model CeyhunArticle {
  id          String    @id @default(cuid()) @map("_id")
  slug        String    @unique
  title       String    @default("{}")
  excerpt     String    @default("{}")
  body        String    @default("{}")
  coverUrl    String?
  category    String? // vaaz | makale | duyuru | tanıklık
  tags        String    @default("[]") // JSON dizi
  readMinutes Int       @default(0)
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime?
  views       Int       @default(0)
  order       Int       @default(0)
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("ceyhun_articles")
}

/// Foto albümü (galeri kategorisi).
model CeyhunAlbum {
  id        String        @id @default(cuid()) @map("_id")
  slug      String        @unique
  title     String        @default("{}")
  note      String        @default("{}")
  coverUrl  String?
  order     Int           @default(0)
  published Boolean       @default(true)
  photos    CeyhunPhoto[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("ceyhun_albums")
}

/// Galeri fotoğrafı.
model CeyhunPhoto {
  id        String       @id @default(cuid()) @map("_id")
  url       String
  caption   String       @default("{}")
  albumId   String?
  album     CeyhunAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  width     Int?
  height    Int?
  order     Int          @default(0)
  published Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@index([albumId, order])
  @@map("ceyhun_photos")
}

/// Video (YouTube / Cloudinary / Vimeo).
model CeyhunVideo {
  id          String   @id @default(cuid()) @map("_id")
  title       String   @default("{}")
  description String   @default("{}")
  provider    String   @default("mux") // yalnızca mux
  videoRef    String // "<assetId>:<playbackId>"
  thumbUrl    String?
  category    String?
  durationSec Int      @default(0)
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  views       Int      @default(0)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
  @@map("ceyhun_videos")
}

// ─────────────────────────── Faz 2 · Biblical Turizm ───────────────────────────

/// Tur kataloğu (İstanbul / 7 Kilise / Kapadokya + özel).
model CeyhunTour {
  id           String   @id @default(cuid()) @map("_id")
  slug         String   @unique // istanbul | seven-churches | cappadocia
  title        String   @default("{}")
  summary      String   @default("{}")
  body         String   @default("{}") // HTML, çok dilli
  coverUrl     String?
  gallery      String   @default("[]") // JSON url dizi
  durationDays Int      @default(1)
  priceFrom    Int      @default(0) // cents
  currency     String   @default("EUR")
  highlights   String   @default("[]") // JSON (çok dilli madde dizi)
  itinerary    String   @default("[]") // JSON (gün gün program)
  order        Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ceyhun_tours")
}

/// Tur rezervasyon başvurusu (yurtdışından gelen ziyaretçiler).
model CeyhunTourApplication {
  id        String    @id @default(cuid()) @map("_id")
  name      String
  email     String
  phone     String?
  country   String?
  tourType  String    @default("istanbul") // istanbul | seven-churches | cappadocia | custom
  groupSize Int       @default(1)
  startDate DateTime?
  endDate   DateTime?
  budget    String?
  needHotel Boolean   @default(true)
  message   String?
  status    String    @default("NEW") // NEW | REVIEWING | QUOTED | CONFIRMED | REJECTED | ARCHIVED
  notes     String?
  locale    String    @default("en")
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("ceyhun_tour_applications")
}

// ─────────────────────────── Faz 3 · Eğitim + Bağış ───────────────────────────

model CeyhunCourse {
  id          String         @id @default(cuid()) @map("_id")
  slug        String         @unique
  title       String         @default("{}")
  description String         @default("{}")
  body        String         @default("{}")
  coverUrl    String?
  priceCents  Int            @default(0) // 0 = ücretsiz
  currency    String         @default("EUR")
  level       String?
  featured    Boolean        @default(false)
  published   Boolean        @default(false)
  order       Int            @default(0)
  lessons     CeyhunLesson[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("ceyhun_courses")
}

model CeyhunLesson {
  id            String       @id @default(cuid()) @map("_id")
  courseId      String
  course        CeyhunCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title         String       @default("{}")
  description   String       @default("{}")
  provider      String       @default("mux") // yalnızca mux
  videoRef      String
  durationSec   Int          @default(0)
  isFreePreview Boolean      @default(false)
  order         Int          @default(0)
  createdAt     DateTime     @default(now())

  @@index([courseId, order])
  @@map("ceyhun_lessons")
}

model CeyhunEnrollment {
  id          String   @id @default(cuid()) @map("_id")
  courseId    String
  userId      String
  email       String?
  status      String   @default("ACTIVE") // ACTIVE | PENDING | REFUNDED
  provider    String? // stripe | paypal | free
  amountCents Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([courseId, userId])
  @@index([userId])
  @@map("ceyhun_enrollments")
}

model CeyhunDonation {
  id          String   @id @default(cuid()) @map("_id")
  name        String?
  email       String?
  userId      String?
  amountCents Int
  currency    String   @default("EUR")
  provider    String   @default("stripe") // stripe | paypal
  providerRef String?
  campaign    String   @default("general") // general | course | prayer
  message     String?
  anonymous   Boolean  @default(false)
  status      String   @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  locale      String   @default("tr")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([campaign])
  @@map("ceyhun_donations")
}

// ─────────────────────────── Faz 4 · Online Dua Toplantısı ───────────────────────────

model CeyhunPrayerMeeting {
  id            String                     @id @default(cuid()) @map("_id")
  slug          String                     @unique
  title         String                     @default("{}")
  description   String                     @default("{}")
  coverUrl      String?
  scheduledAt   DateTime
  durationMin   Int                        @default(60)
  timezone      String                     @default("Europe/Istanbul")
  capacity      Int                        @default(0) // 0 = sınırsız
  streamCallId  String? // Stream video call id
  joinInfo      String                     @default("{}")
  status        String                     @default("SCHEDULED") // SCHEDULED | LIVE | ENDED | CANCELLED
  published     Boolean                    @default(true)
  registrations CeyhunPrayerRegistration[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([scheduledAt])
  @@map("ceyhun_prayer_meetings")
}

model CeyhunPrayerRegistration {
  id            String              @id @default(cuid()) @map("_id")
  meetingId     String
  meeting       CeyhunPrayerMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name          String
  email         String
  userId        String?
  prayerRequest String?
  status        String              @default("REGISTERED") // REGISTERED | ATTENDED | CANCELLED
  createdAt     DateTime            @default(now())

  @@index([meetingId])
  @@map("ceyhun_prayer_registrations")
}

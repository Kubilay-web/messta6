// Agency → School karşılığı (Emlak ofisi / şirketi)
model Agency {
  id           String  @id @default(cuid()) @map("_id")
  name         String
  logo         String?
  primaryEmail String?
  slug         String  @unique
  phone        String?
  address      String?
  city         String?
  taxNumber    String? // Vergi numarası
  licenseNo    String? // Ticaret ruhsatı

  ownerUserId String? // Ofisi oluşturan/sahibi kullanıcı (çoklu ofis + geçiş için)

  siteEnabled    Boolean @default(false)
  siteCompletion Int     @default(0)

  users             User[]
  agencyLogs        AgencyLog[]
  galleryImages     AgencyGalleryImage[]
  galleryCategories AgencyGalleryCategory[]
  events            AgencyEvent[]
  recentActivities  AgencyActivity[]
  reminders         AgencyReminder[]
  departments       AgencyDepartment[]
  agents            Agent[]
  clients           PropertyClient[]
  properties        PropertyRealEstate[]
  listings          Listing[]
  contracts         PropertyContract[]
  newsItems         AgencyNewsItem[]
  sections          AgencySection[]
  contactMessages   AgencyContactMessage[]

  // CRM
  crmPipelines  CrmPipeline[]
  crmLeads      Lead[]
  crmTasks      CrmTask[]
  crmActivities CrmActivity[]

  // Gelişmiş ERP (teklif, muhasebe, kira, iletişim)
  offers              PropertyOffer[]
  reservations        PropertyReservation[]
  commissions         Commission[]
  invoices2           AgencyInvoice[]
  expenses            AgencyExpense[]
  payrolls            AgentPayroll[]
  maintenanceRequests MaintenanceRequest[]
  communicationLogs   CommunicationLog[]
  notifications       AgencyNotification[]
  auditLogs           AgencyAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@map("agencies")
}

// AgencyDepartment → Department karşılığı
model AgencyDepartment {
  id   String @id @default(cuid()) @map("_id")
  name String
  slug String @unique

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  managerId        String?
  managerName      String?
  managerStartDate DateTime?
  budget           Float?
  budgetYear       String?

  agents Agent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agency-departments")
}

// Agent → Teacher karşılığı (Emlak danışmanı / broker)
model Agent {
  id String @id @default(cuid()) @map("_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  title         String
  firstName     String
  lastName      String
  email         String            @unique
  phone         String            @unique
  whatsappNo    String?
  dateOfBirth   DateTime?
  gender        GayrimenkulGender
  imageUrl      String?
  NIN           String            @unique // TC Kimlik No
  password      String?
  isActive      Boolean           @default(true)
  lastLogin     DateTime?
  contactMethod String

  employeeId     String           @unique
  dateOfJoining  DateTime
  designation    String // "Kıdemli Danışman", "Şube Müdürü" vb.
  departmentName String
  department     AgencyDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId   String
  licenseNo      String? // Emlak danışmanlığı belgesi no
  qualification  String
  experience     Int?
  bio            String?
  skills         String?
  socialLinks    Json?
  commissionRate Float?           @default(2.5) // Komisyon oranı (%)

  specializationTypes  PropertyType[]
  specializationCities String[]

  agency     Agency @relation(fields: [agencyId], references: [id])
  agencyId   String
  agencyName String

  listings   Listing[]
  contracts  PropertyContract[]
  documents  AgentDocument[]
  attendance AgentAttendance[]
  leaves     AgentLeave[]
  visits     PropertyVisit[]

  // CRM
  crmLeads      Lead[]
  crmTasks      CrmTask[]
  crmActivities CrmActivity[]

  // Gelişmiş ERP
  offers              PropertyOffer[]
  reservations        PropertyReservation[]
  commissions         Commission[]
  expenses            AgencyExpense[]
  payrolls            AgentPayroll[]
  maintenanceRequests MaintenanceRequest[]
  communicationLogs   CommunicationLog[]
  notifications       AgencyNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([departmentId])
  @@map("agents")
}

// PropertyClient → Parent + Student karşılığı (Müşteri: alıcı / kiracı / satıcı)
model PropertyClient {
  id String @id @default(cuid()) @map("_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  title         String
  firstName     String
  lastName      String
  email         String   @unique
  phone         String   @unique
  whatsappNo    String?
  gender        String
  dob           DateTime
  nationality   String
  imageUrl      String?
  NIN           String   @unique // TC Kimlik No
  contactMethod String
  occupation    String?
  address       String
  password      String

  isBuyer    Boolean @default(true) // Alıcı
  isSeller   Boolean @default(false) // Satıcı
  isTenant   Boolean @default(false) // Kiracı
  isLandlord Boolean @default(false) // Kiraya veren / mülk sahibi

  minBudget              Float?
  maxBudget              Float?
  currency               String         @default("TRY")
  preferredPropertyTypes PropertyType[]
  preferredCities        String[]
  notes                  String?

  agencyId   String
  agencyName String
  agency     Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  contracts     PropertyContract[]
  visits        PropertyVisit[]
  interests     ClientInterest[]
  savedSearches ClientSavedSearch[]

  // CRM
  crmLeads Lead[]

  // Gelişmiş ERP
  ownedProperties     PropertyRealEstate[]  @relation("PropertyOwner")
  offers              PropertyOffer[]
  reservations        PropertyReservation[]
  invoices2           AgencyInvoice[]
  maintenanceRequests MaintenanceRequest[]
  communicationLogs   CommunicationLog[]
  notifications       AgencyNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@map("property-clients")
}

// Property → Class + Subject karşılığı (Mülk)
model PropertyRealEstate {
  id    String @id @default(cuid()) @map("_id")
  title String
  slug  String @unique

  address      String
  city         String
  district     String // İlçe
  neighborhood String? // Mahalle
  zipCode      String?
  latitude     Float?
  longitude    Float?

  propertyType  PropertyType
  status        PropertyStatus @default(AVAILABLE)
  grossArea     Float? // Brüt alan (m²)
  netArea       Float? // Net alan (m²)
  roomCount     String? // "3+1", "2+1" vb.
  bathroomCount Int?
  floorNo       Int?
  totalFloors   Int?
  buildingAge   Int? // Bina yaşı (yıl)
  heatingType   String?
  hasElevator   Boolean        @default(false)
  hasParking    Boolean        @default(false)
  isFurnished   Boolean        @default(false)
  hasGarden     Boolean        @default(false)
  hasPool       Boolean        @default(false)
  hasBalcony    Boolean        @default(false)
  isFeatured    Boolean        @default(false)
  description   String?
  notes         String?

  // Mülk sahibi: kayıtlı müşteriye (satıcı/mülk sahibi) bağlanabilir.
  // ownerName/ownerPhone/ownerNIN, ownerId yoksa veya snapshot için tutulur.
  ownerId    String?
  owner      PropertyClient? @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerName  String?
  ownerPhone String?
  ownerNIN   String? // TC Kimlik No

  price    Float?
  currency String @default("TRY")

  agencyId   String
  agencyName String
  agency     Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  listings            Listing[]
  documents           PropertyDocument[]
  images              PropertyImage[]
  visits              PropertyVisit[]
  contracts           PropertyContract[]
  offers              PropertyOffer[]
  reservations        PropertyReservation[]
  maintenanceRequests MaintenanceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([ownerId])
  @@index([status])
  @@index([propertyType])
  @@index([city])
  @@map("properties")
}

// Listing → Exam karşılığı (İlan)
// İlan kanalı: ofis (AGENCY) mi yoksa bireysel sahibinden (INDIVIDUAL) mı
enum ListingChannel {
  AGENCY
  INDIVIDUAL
}

// İlan moderasyon durumu (özellikle bireysel ilanlar için onay kuyruğu)
enum ListingModeration {
  PENDING
  APPROVED
  REJECTED
}

// Ziyaretçinin favorilediği ilan (pazar yeri hesabı = User)
model MarketFavorite {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@map("market-favorites")
}

// Ziyaretçinin kaydettiği arama kriterleri
model MarketSavedSearch {
  id           String   @id @default(cuid()) @map("_id")
  userId       String
  name         String
  listingType  String?
  propertyType String?
  city         String?
  minPrice     Float?
  maxPrice     Float?
  rooms        String?
  q            String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("market-saved-searches")
}

model Listing {
  id        String @id @default(cuid()) @map("_id")
  title     String
  listingNo String @unique // İlan numarası

  listingType ListingType
  status      ListingStatus @default(ACTIVE)

  // Pazar yeri: bireysel (sahibinden) ilanlar için kanal + ilan sahibi kullanıcı
  channel          ListingChannel    @default(AGENCY)
  ownerUserId      String? // INDIVIDUAL ilanlarda ilanı veren User
  moderationStatus ListingModeration @default(APPROVED) // bireysel ilanlar PENDING başlar
  featuredUntil    DateTime? // ücretli öne çıkarma bitiş tarihi
  videoUrl         String? // tanıtım videosu
  virtualTourUrl   String? // 360° sanal tur linki

  askingPrice  Float
  currency     String  @default("TRY")
  monthlyRent  Float? // Aylık kira (kiralık ilanlar için)
  deposit      Float? // Depozito
  isNegotiable Boolean @default(true)

  publishedAt DateTime?
  expiresAt   DateTime?
  isPublic    Boolean   @default(true)
  views       Int       @default(0)
  description String?
  highlights  String[]

  propertyId String
  property   PropertyRealEstate @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agentId   String?
  agentName String
  agent     Agent?  @relation(fields: [agentId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  contracts PropertyContract[]
  visits    PropertyVisit[]
  interests ClientInterest[]

  // CRM
  crmLeads Lead[]

  // Gelişmiş ERP
  offers            PropertyOffer[]
  reservations      PropertyReservation[]
  communicationLogs CommunicationLog[]

  // Pazar yeri
  favorites MarketFavorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([propertyId])
  @@index([agentId])
  @@index([status])
  @@index([listingType])
  @@index([ownerUserId])
  @@map("listings")
}

// PropertyContract → Marksheet + SchoolFeePayment karşılığı (Sözleşme)

model PropertyContract {
  id         String @id @default(cuid()) @map("_id")
  contractNo String @unique

  contractType ContractType
  status       ContractStatus @default(DRAFT)

  startDate  DateTime
  endDate    DateTime? // Kiralık sözleşmeler için bitiş tarihi
  signedDate DateTime?

  salePrice   Float?
  rentalPrice Float?
  deposit     Float?
  commission  Float?
  currency    String  @default("TRY")
  notes       String?

  // Kira yönetimi (kiralık sözleşmeler için)
  rentIncreaseRate Float? // Yıllık kira artış oranı (%)
  rentPaymentDay   Int? // Ayın kaçında kira ödenecek (1-31)
  nextRentDueDate  DateTime? // Bir sonraki kira tahakkuk tarihi
  autoRenew        Boolean   @default(false) // Otomatik yenileme

  propertyId String
  property   PropertyRealEstate @relation(fields: [propertyId], references: [id])

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  agentId   String
  agentName String
  agent     Agent  @relation(fields: [agentId], references: [id])

  clientId   String
  clientName String
  client     PropertyClient @relation(fields: [clientId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  payments  ContractPayment[]
  documents ContractDocument[]

  // Gelişmiş ERP
  commissions         Commission[]
  invoices2           AgencyInvoice[]
  maintenanceRequests MaintenanceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([propertyId])
  @@index([agentId])
  @@index([clientId])
  @@index([status])
  @@map("property-contracts")
}

